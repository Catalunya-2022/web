{
  "name": "catalunya-2022-web",
  "version": "0.1.0",
  "description": "Trilingual documentation website for the Catalunya 2022 policy document",
  "license": "MIT",
  "private": true,
  "author": "Catalunya 2022 (https://2022.cat)",
  "homepage": "https://2022.cat",
  "engines": {
    "node": "22.x"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/catalunya-2022/web.git"
  },
  "bugs": {
    "url": "https://github.com/catalunya-2022/web/issues"
  },
  "keywords": [
    "catalunya",
    "policy",
    "documentation",
    "nextjs",
    "i18n",
    "catalan"
  ],
  "scripts": {
    "generate:llms": "node --import tsx scripts/generate-llms-files.ts",
    "generate:search": "node --import tsx scripts/generate-search-corpus.ts",
    "generate:og": "node --import tsx scripts/generate-og-images.tsx",
    "generate:icons": "node --import tsx scripts/generate-icons.ts",
    "generate:manifests": "node --import tsx scripts/generate-manifests.ts",
    "generate:dates": "node --import tsx scripts/generate-content-dates.ts",
    "indexnow": "node --import tsx scripts/indexnow-ping.ts",
    "prebuild": "node --import tsx scripts/generate-llms-files.ts && node --import tsx scripts/generate-search-corpus.ts && node --import tsx scripts/generate-og-images.tsx && node --import tsx scripts/generate-manifests.ts && node --import tsx scripts/generate-content-dates.ts",
    "dev": "node --import tsx scripts/generate-llms-files.ts && node --import tsx scripts/generate-search-corpus.ts && node --import tsx scripts/generate-manifests.ts && node --import tsx scripts/generate-content-dates.ts && next dev",
    "build": "next build",
    "start": "next start",
    "start:e2e": "npm run build && next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots"
  },
  "dependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "flexsearch": "^0.8.212",
    "lucide-react": "^0.563.0",
    "next": "^16.2.10",
    "next-intl": "^4.8.2",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "rehype-sanitize": "^6.0.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@resvg/resvg-js": "^2.6.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^28.1.0",
    "png-to-ico": "3.0.1",
    "satori": "^0.25.0",
    "shadcn": "^3.8.4",
    "sharp": "0.34.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
