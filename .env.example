# Plausible Analytics — set to your domain to enable tracking (e.g., 2022.cat)
# Leave empty to disable analytics (dev, forks, CI).
# In production the script is served same-origin at /js/pa.js.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Build tuning (optional) — how many OG images scripts/generate-og-images.tsx
# renders concurrently. Defaults to 8; lower it on memory-constrained machines.
#OG_BATCH_SIZE=8
